<!-- Hero Section -->
<section class="flex items-center justify-center px-4 pt-20 pb-16 bg-linear-to-br from-blue-100 to-blue-200">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-center">
    <div>
      <h1 class="text-5xl text-center font-extrabold leading-tight mb-6">
        Collect Feedback That Matters
      </h1>
      <p class="text-xl text-center opacity-90 mb-8">
        Create beautiful surveys, gather insights, and make data-driven decisions with LetSurvey
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <%= link_to "Get Started Free", widgets_path,
            class: "px-8 py-4 bg-blue-600 text-white font-semibold rounded-md hover:bg-blue-700 transition-colors" %>
        <%= link_to "Pricing", "#pricing",
            class: "px-8 py-4 bg-white text-blue-600 font-semibold rounded-md hover:bg-blue-50 transition-colors shadow-md" %> 
      </div>
    </div>

    <div>
      <%= image_tag "dashboard_preview.svg", alt: "Dashboard Preview", class: "rounded-xl shadow-xl w-full" %>
    </div>
  </div>
</section>

<!-- Features Section -->
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Everything you need to collect feedback</h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Powerful features to help you create, distribute, and analyze surveys
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <!-- Feature 1 -->
      <div class="text-center p-6">
        <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Easy Survey Creation</h3>
        <p class="text-gray-600">
          Create professional surveys in minutes with our intuitive drag-and-drop interface
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="text-center p-6">
        <div class="bg-green-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Real-time Analytics</h3>
        <p class="text-gray-600">
          Get instant insights with beautiful charts and detailed response analytics
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="text-center p-6">
        <div class="bg-purple-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Secure & Private</h3>
        <p class="text-gray-600">
          Your data is protected with enterprise-grade security and privacy controls
        </p>
      </div>
    </div>
  </div>
</section>

<!-- How It Works Section -->
<section class="py-20 bg-blue-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">How It Works</h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Get started in three simple steps
      </p>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="text-center">
          <div class="bg-blue-600 text-white w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 text-xl font-bold">
            1
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Create Your Survey</h3>
          <p class="text-gray-600">
            Choose from multiple question types and customize your survey to match your brand
          </p>
        </div>

        <!-- Step 2 -->
        <div class="text-center">
          <div class="bg-blue-600 text-white w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 text-xl font-bold">
            2
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Share & Collect</h3>
          <p class="text-gray-600">
            Share your survey link via email, social media, or embed it on your website
          </p>
        </div>

        <!-- Step 3 -->
        <div class="text-center">
          <div class="bg-blue-600 text-white w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 text-xl font-bold">
            3
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Analyze Results</h3>
          <p class="text-gray-600">
            View real-time responses, export data, and make informed decisions
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-20 bg-white" id="pricing">
  <div class="max-w-4xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Choose Your Plan</h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Flexible pricing options to suit your needs
      </p>
    </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <% @plans.each_with_index do |plan, index| %>
          <div class="bg-white border-2 <%= index == 1 ? 'border-blue-500 shadow-lg' : 'border-gray-200' %> rounded-lg p-6 <%= index == 1 ? '' : 'hover:border-blue-500' %> transition-colors relative">
            <% if index == 1 %>
              <div class="absolute top-0 right-0 bg-blue-500 text-white px-3 py-1 rounded-bl-lg text-xs font-semibold">
                POPULAR
              </div>
            <% end %>
            <div class="text-center mb-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2"><%= plan.name %></h3>
              <div class="mb-4">
                <span class="text-4xl font-bold text-gray-900">$<%= plan.monthly_price.to_i %></span>
                <span class="text-gray-600">/month</span>
              </div>
              <p class="text-sm text-gray-600">
                <%= plan.name == "Free" ? "Perfect for getting started" : plan.name == "Regular" ? "For growing businesses" : "For enterprises" %>
              </p>
            </div>

            <ul class="space-y-3 mb-6">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-gray-700">
                  <%= plan.max_widgets ? "Up to #{plan.max_widgets} widgets" : "Unlimited widgets" %>
                </span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-gray-700">
                  <%= plan.name == "Free" ? "Basic analytics" : plan.name == "Regular" ? "Advanced analytics" : "Full analytics suite" %>
                </span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-gray-700">
                  <%= plan.name == "Free" ? "Email support" : plan.name == "Regular" ? "Priority support" : "24/7 priority support" %>
                </span>
              </li>
              <% if plan.name != "Free" %>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-sm text-gray-700">
                    <%= plan.name == "Regular" ? "Custom branding" : "Advanced customization" %>
                  </span>
                </li>
              <% end %>
              <% if plan.name == "Premium" %>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-sm text-gray-700">API access</span>
                </li>
              <% end %>
            </ul>

            <%= form_with url: subscription_path, method: :post, local: true, class: "mt-6" do |form| %>
              <%= form.hidden_field "subscription[plan_id]", value: plan.id %>
              <%= form.hidden_field "subscription[brand]", value: "" %>
              <%= form.submit "Select #{plan.name} Plan", 
                  class: "w-full px-4 py-2 #{index == 1 ? 'bg-blue-600 text-white hover:bg-blue-700' : index == 2 ? 'border-2 border-purple-500 text-purple-700 hover:bg-purple-50' : 'border-2 border-gray-300 text-gray-700 hover:bg-gray-50'} font-medium rounded-lg cursor-pointer transition-colors" %>
            <% end %>
          </div>
        <% end %>
      </div>
  </div>
</section>

<!-- CTA Section -->
<section class="lg:mx-12 py-20 bg-blue-500 text-white">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-4xl font-bold mb-4">Ready to get started?</h2>
    <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
      Join thousands of businesses collecting valuable feedback with LetSurvey
    </p>
    <%= link_to "Create Your First Widget", widgets_path, 
