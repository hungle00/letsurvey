<div class="min-h-screen bg-background py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <!-- Widget Header -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8 mb-6">
      <h1 class="text-4xl font-bold text-gray-900 mb-3"><%= @widget.title %></h1>
      <% if @widget.description.present? %>
        <p class="text-lg text-gray-600"><%= @widget.description %></p>
      <% end %>
    </div>

    <!-- Survey Form -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8">
      <%= form_with url: submit_widget_form_path(@widget.slug), local: true, class: "space-y-6", data: { controller: "survey-form" } do |form| %>
        <% if @widget.require_email? %>
          <div class="pb-6 border-b border-gray-200">
            <div class="mb-4">
              <%= form.label :respondent_email, "Email Address", 
                  class: "block text-lg font-medium text-gray-900 mb-2" %>
              <span class="text-red-500 text-sm">* Required</span>
            </div>
            <%= form.email_field :respondent_email, 
                required: true,
                placeholder: "Enter your email address",
                value: params[:respondent_email],
                class: "w-full px-4 py-3 border-2 border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all duration-300 hover:border-blue-400" %>
            <% if @feedback&.errors&.[](:respondent_email)&.any? %>
              <p class="mt-1 text-sm text-red-600"><%= @feedback.errors[:respondent_email].first %></p>
            <% end %>
          </div>
        <% end %>

        <% @questions.each_with_index do |question, index| %>
          <div class="pb-6 <%= 'border-b border-gray-200' unless index == @questions.length - 1 %>">
            <!-- Question Text -->
            <div class="mb-4">
              <%= form.label "question_#{question.id}", question.question_text, 
                  class: "block text-lg font-medium text-gray-900 mb-2" %>
              <% if question.required? %>
                <span class="text-red-500 text-sm">* Required</span>
              <% end %>
            </div>

            <!-- Question Input based on type -->
            <% case question.question_type %>
            <% when "rating" %>
              <div class="flex items-center gap-2">
                <% (question.min_value || 1).upto(question.max_value || 5) do |value| %>
                  <label class="flex items-center justify-center w-14 h-14 border-2 border-gray-300 rounded-xl cursor-pointer hover:border-blue-500 hover:bg-blue-50 hover:shadow-md transition-all duration-300 peer-checked:border-blue-600 peer-checked:bg-blue-100 peer-checked:shadow-lg">
                    <%= form.radio_button "question_#{question.id}", value, 
                        required: question.required?,
                        class: "sr-only peer" %>
                    <span class="text-xl font-bold text-gray-700 peer-checked:text-blue-600"><%= value %></span>
                  </label>
                <% end %>
              </div>

            <% when "single_choice" %>
              <div class="space-y-2">
                <% question.options.ordered.each do |option| %>
                  <label class="flex items-center p-4 border-2 border-gray-300 rounded-xl cursor-pointer hover:border-blue-500 hover:bg-blue-50 hover:shadow-md transition-all duration-300 group">
                    <%= form.radio_button "question_#{question.id}", option.id, 
                        required: question.required?,
                        class: "w-5 h-5 text-blue-600 border-gray-300 focus:ring-blue-500 focus:ring-2" %>
                    <span class="ml-3 text-gray-700 font-medium group-hover:text-blue-600 transition-colors"><%= option.option_text %></span>
                  </label>
                <% end %>
                <% if question.allow_other? %>
                  <div class="mt-4">
                    <label class="flex items-center p-4 border-2 border-gray-300 rounded-xl cursor-pointer hover:border-blue-500 hover:bg-blue-50 hover:shadow-md transition-all duration-300 group">
                      <%= form.radio_button "question_#{question.id}", "other", 
                          required: question.required?,
                          class: "w-5 h-5 text-blue-600 border-gray-300 focus:ring-blue-500 focus:ring-2",
                          data: { action: "change->survey-form#toggleOther" } %>
                      <span class="ml-3 text-gray-700 font-medium group-hover:text-blue-600 transition-colors">Other</span>
                    </label>
                    <div class="mt-3" data-survey-form-target="otherField" style="display: none;">
                      <%= form.text_field "question_#{question.id}_other", 
                          placeholder: "Please specify",
                          class: "w-full px-4 py-3 border-2 border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all duration-300 hover:border-blue-400" %>
                    </div>
                  </div>
                <% end %>
              </div>

            <% when "multiple_choice" %>
              <div class="space-y-2">
                <% question.options.ordered.each do |option| %>
                  <label class="flex items-center p-4 border-2 border-gray-300 rounded-xl cursor-pointer hover:border-blue-500 hover:bg-blue-50 hover:shadow-md transition-all duration-300 group">
                    <%= form.check_box "question_#{question.id}[]", 
                        { multiple: true }, 
                        option.id, 
                        nil,
                        class: "w-5 h-5 text-blue-600 border-gray-300 rounded focus:ring-blue-500 focus:ring-2" %>
                    <span class="ml-3 text-gray-700 font-medium group-hover:text-blue-600 transition-colors"><%= option.option_text %></span>
                  </label>
                <% end %>
                <% if question.allow_other? %>
                  <div class="mt-4">
                    <label class="flex items-center p-4 border-2 border-gray-300 rounded-xl cursor-pointer hover:border-blue-500 hover:bg-blue-50 hover:shadow-md transition-all duration-300 group">
                      <%= form.check_box "question_#{question.id}[]", 
                          { multiple: true }, 
                          "other", 
                          nil,
                          class: "w-5 h-5 text-blue-600 border-gray-300 rounded focus:ring-blue-500 focus:ring-2",
                          data: { action: "change->survey-form#toggleOther" } %>
                      <span class="ml-3 text-gray-700 font-medium group-hover:text-blue-600 transition-colors">Other</span>
                    </label>
                    <div class="mt-3" data-survey-form-target="otherField" style="display: none;">
                      <%= form.text_field "question_#{question.id}_other", 
                          placeholder: "Please specify",
                          class: "w-full px-4 py-3 border-2 border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all duration-300 hover:border-blue-400" %>
                    </div>
                  </div>
                <% end %>
              </div>

            <% when "text" %>
              <%= form.text_area "question_#{question.id}", 
                  rows: 4,
                  required: question.required?,
                  placeholder: question.placeholder.presence || "Enter your answer...",
                  class: "w-full px-4 py-3 border-2 border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all duration-300 hover:border-blue-400" %>
            <% end %>
          </div>
        <% end %>

        <!-- Submit Button -->
        <div class="pt-6 border-t border-gray-200">
          <%= form.submit "Submit Survey", 
              class: "w-full px-6 py-4 bg-gradient-to-r from-blue-600 to-teal-600 hover:from-blue-700 hover:to-teal-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105 cursor-pointer text-lg" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

