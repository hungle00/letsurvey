<div class="flex w-full min-h-screen">
  <%= render "shared/sidebar" %>

  <div class="flex-1 p-8 bg-background mx-auto">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8">
        <h1 class="text-4xl font-bold mb-2 text-gray-900">Subscription</h1>
        <p class="text-gray-600 mt-1">
          Manage your <span class="font-semibold text-blue-600">subscription plan</span>
        </p>
      </div>

      <%= render "shared/flash" %>

      <% if Current.user.has_active_subscription? %>
        <!-- Current Subscription Card -->
        <div class="bg-white shadow-lg border border-gray-200 rounded-2xl p-8 mb-6">
          <div class="flex items-start justify-between mb-6">
            <div>
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Current Subscription</h2>
              <p class="text-gray-600">Your <span class="font-semibold text-blue-600">active subscription</span> details</p>
            </div>
            <span class="px-4 py-2 text-sm font-semibold rounded-full <%= subscription_status_badge_class(@subscription.status) %>">
              <%= @subscription.status.humanize %>
            </span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
            <div class="p-4 bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl">
              <p class="text-sm text-blue-600 font-medium mb-1">Plan Type</p>
              <p class="text-xl font-bold text-blue-900"><%= @subscription.plan&.name || "N/A" %></p>
            </div>
            <div class="p-4 bg-gradient-to-br from-teal-50 to-teal-100 rounded-xl">
              <p class="text-sm text-teal-600 font-medium mb-1">Max Widgets</p>
              <p class="text-xl font-bold text-teal-900">
                <%= @subscription.plan&.max_widgets ? @subscription.plan.max_widgets : "Unlimited" %>
              </p>
            </div>
            <div class="p-4 bg-gradient-to-br from-emerald-50 to-emerald-100 rounded-xl">
              <p class="text-sm text-emerald-600 font-medium mb-1">Monthly Price</p>
              <p class="text-xl font-bold text-emerald-900">
                $<%= @subscription.plan&.monthly_price || 0 %>
              </p>
            </div>
            <div class="p-4 bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl">
              <p class="text-sm text-purple-600 font-medium mb-1">Start Date</p>
              <p class="text-xl font-bold text-purple-900">
                <%= @subscription.subscription_start_date&.strftime("%b %d, %Y") || "N/A" %>
              </p>
            </div>
            <div class="p-4 bg-gradient-to-br from-pink-50 to-pink-100 rounded-xl">
              <p class="text-sm text-pink-600 font-medium mb-1">End Date</p>
              <p class="text-xl font-bold text-pink-900">
                <%= @subscription.subscription_end_date&.strftime("%b %d, %Y") || "Never" %>
              </p>
            </div>
          </div>

          <% if @subscription.brand.present? %>
            <div class="pt-6 border-t border-gray-200">
              <p class="text-sm text-gray-500 mb-1">Brand/Company</p>
              <p class="text-lg font-semibold text-gray-900"><%= @subscription.brand %></p>
            </div>
          <% end %>

          <% if @subscription.trial_end_date.present? && @subscription.trial_end_date > Date.current %>
            <div class="mt-4 p-4 bg-blue-50 border border-blue-200 rounded-lg">
              <p class="text-sm text-blue-700">
                <strong>Trial Period:</strong> Your trial ends on <%= @subscription.trial_end_date.strftime("%B %d, %Y") %>
              </p>
            </div>
          <% end %>
        </div>
      <% else %>
        <!-- Subscription Plans Selection -->
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Choose Your Plan</h2>
          <p class="text-gray-600">Select a <span class="font-semibold text-blue-600">subscription plan</span> that fits your needs</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <% @plans.each_with_index do |plan, index| %>
            <div class="bg-white border-2 <%= index == 1 ? 'border-blue-500 shadow-xl' : 'border-gray-200 shadow-md' %> rounded-2xl p-6 <%= index == 1 ? '' : 'hover:border-blue-500 hover:shadow-xl' %> transition-all duration-300 hover:-translate-y-1 relative">
              <% if index == 1 %>
                <div class="absolute top-0 right-0 bg-blue-500 text-white px-3 py-1 rounded-bl-lg text-xs font-semibold">
                  POPULAR
                </div>
              <% end %>
              <div class="text-center mb-6">
                <h3 class="text-xl font-bold text-gray-900 mb-2"><%= plan.name %></h3>
                <div class="mb-4">
                  <span class="text-4xl font-bold text-gray-900">$<%= plan.monthly_price.to_i %></span>
                  <span class="text-gray-600">/month</span>
                </div>
                <p class="text-sm text-gray-600">
                  <%= plan.name == "Free" ? "Perfect for getting started" : plan.name == "Regular" ? "For growing businesses" : "For enterprises" %>
                </p>
              </div>

              <ul class="space-y-3 mb-6">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-sm text-gray-700">
                    <%= plan.max_widgets ? "Up to #{plan.max_widgets} widgets" : "Unlimited widgets" %>
                  </span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-sm text-gray-700">
                    <%= plan.name == "Free" ? "Basic analytics" : plan.name == "Regular" ? "Advanced analytics" : "Full analytics suite" %>
                  </span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-sm text-gray-700">
                    <%= plan.name == "Free" ? "Email support" : plan.name == "Regular" ? "Priority support" : "24/7 priority support" %>
                  </span>
                </li>
                <% if plan.name != "Free" %>
                  <li class="flex items-start">
                    <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-gray-700">
                      <%= plan.name == "Regular" ? "Custom branding" : "Advanced customization" %>
                    </span>
                  </li>
                <% end %>
                <% if plan.name == "Premium" %>
                  <li class="flex items-start">
                    <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="text-sm text-gray-700">API access</span>
                  </li>
                <% end %>
              </ul>

              <%= form_with url: subscription_path, method: :post, local: true, class: "mt-6" do |form| %>
                <%= form.hidden_field "subscription[plan_id]", value: plan.id %>
                <%= form.hidden_field "subscription[brand]", value: "" %>
                <%= form.submit "Select #{plan.name} Plan", 
                    class: "w-full px-4 py-2 #{index == 1 ? 'bg-gradient-to-r from-blue-600 to-teal-600 hover:from-blue-700 hover:to-teal-700 text-white shadow-lg hover:shadow-xl' : index == 2 ? 'border-2 border-purple-500 text-purple-700 hover:bg-purple-50' : 'border-2 border-gray-300 text-gray-700 hover:bg-gray-50'} font-semibold rounded-xl cursor-pointer transition-all duration-300 transform hover:scale-105" %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
