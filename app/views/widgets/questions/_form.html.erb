<%= form_with model: [widget, question], 
    url: question.persisted? ? widget_question_path(widget, question) : widget_questions_path(widget),
    method: question.persisted? ? :patch : :post,
    local: true, 
    class: "space-y-5",
    data: { turbo_frame: question.persisted? ? dom_id(question) : "new_question" } do |form| %>
  <% if question.errors.any? %>
    <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
      <h3 class="text-sm font-medium text-red-800 mb-2">
        <%= pluralize(question.errors.count, "error") %> prohibited this question from being saved:
      </h3>
      <ul class="list-disc list-inside text-sm text-red-700">
        <% question.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Question Text -->
  <div>
    <div class="flex justify-between items-center mb-1">
      <%= form.label :question_text, "Question Text", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <span class="mr-2 px-2 py-1 text-xs font-medium bg-amber-100 text-amber-700 rounded hidden"
        id="question-text-label"></span>
    </div>
    <%= form.text_area :question_text, 
        rows: 2,
        class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors",
        placeholder: "Enter your question here..." %>
  </div>

  <div data-controller="toggle-field">
    <!-- Question Type -->
    <div class="flex gap-4 mb-4">
      <div class="flex-1">
        <%= form.label :question_type, "Question Type", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :question_type, 
            options_for_select(question_type_options, question.question_type),
            { prompt: "Select question type" },
            { 
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors question-type-select",
              data: { action: "change->toggle-field#toggle" }
            } %>
      </div>

      <div class="flex-1">
        <%= form.label :linked_product_id, "Select Product", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :linked_product_id,
            options_for_select(product_options, question.linked_product_id),
            { prompt: "Select a product to link" },
            {
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors",
              data: { action: "change->toggle-field#applyOption" }
            } %>
        <p class="mt-1 text-sm text-gray-500">Optionally link this question to a specific product.</p>
      </div>
    </div>

    <!-- Question Options (only for single_choice and multiple_choice) -->
    <div class="question-options-container my-2 p-4 pl-3 border-l-4 border-indigo-500" 
      data-toggle-field-target="questionOptions"
      data-controller="nested-rondo" 
      data-nested-rondo-field-class-value="option-field">
      <p class="text-sm text-gray-500 mb-3">Add up options for this question</p>
      <div data-nested-rondo-target="fieldContain">
        <%= form.fields_for :options do |option| %>
          <%= render "option_fields", f: option %>
        <% end %>
      </div>
      <div class="block text-sm font-medium text-gray-700">
        <%= link_to_add_association "Add Option", form, :options %>
      </div>

      <!-- Allow Other (for choice questions) -->
      <div data-toggle-field-target="allowOther" class="mt-3 flex items-center" style="display: none;">
        <%= form.check_box :allow_other, 
            class: "w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
        <%= form.label :allow_other, "Allow 'Other' option", class: "ml-2 text-sm font-medium text-gray-700" %>
        <p class="ml-2 text-sm text-gray-500">(For single/multiple choice questions)</p>
      </div>
    </div>

    <!-- Min and Max Value (only for rating) -->
    <div data-toggle-field-target="valueRange" style="display: none;">
      <p class="block text-sm font-medium text-gray-700 mb-2">
        Value Range
        <span class="ml-2 text-sm text-gray-500">(For rating questions)</span>
      </p>
      <div class="flex gap-4">
        <div class="flex-1">
          <%= form.label :min_value, "Minimum Value", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.number_field :min_value, 
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors",
              placeholder: "e.g., 1" %>
        </div>
        <div class="flex-1">
          <%= form.label :max_value, "Maximum Value", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.number_field :max_value, 
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors",
              placeholder: "e.g., 5" %>
        </div>
      </div>
    </div>

    <!-- Placeholder -->
    <div data-toggle-field-target="placeholder">
      <%= form.label :placeholder, "Placeholder Text", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :placeholder, 
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors",
          placeholder: "Enter placeholder text..." %>
      <p class="mt-1 text-sm text-gray-500">(For text/email questions)</p>
    </div>
  </div>

  <div class="flex items-center">
    <%= form.check_box :required, 
        class: "w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
    <%= form.label :required, "Mark as required", class: "ml-2 text-sm font-medium text-gray-700" %>
  </div>

  <!-- Form Actions -->
  <div class="pt-4 border-t border-gray-200 flex items-center justify-end gap-3">
    <% if question.persisted? %>
      <%= link_to widget_questions_path(widget), 
          class: "px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-colors",
          data: { turbo_frame: dom_id(question) } do %>
        Cancel
      <% end %>
    <% end %>
    <%= form.submit question.persisted? ? "Update Question" : "Create Question", 
        class: "px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
  </div>
<% end %>

