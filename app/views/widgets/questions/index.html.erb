<div class="flex w-full min-h-screen">
  <%= render "shared/sidebar" %>

  <div class="flex-1 p-8">
    <div class="mb-6">
      <%= link_to widget_path(@widget), 
          class: "inline-flex items-center text-gray-600 hover:text-gray-900 mb-4" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Widget
      <% end %>

      <div class="flex items-start justify-between">
        <p class="text-2xl text-gray-600 mt-1 font-bold"><%= @widget.title %></p>
      </div>
    </div>

    <% if flash[:notice] %>
      <div class="mb-4 p-4 bg-green-50 text-green-700 rounded-lg">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="mb-4 p-4 bg-red-50 text-red-700 rounded-lg">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- Questions List -->
    <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Existing Questions</h2>
      
      <% if @questions.any? %>
        <div class="space-y-4">
          <% @questions.each do |question| %>
            <div class="p-4 border border-gray-200 rounded-lg hover:border-blue-300 transition-colors">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="px-2 py-1 text-xs font-medium bg-blue-100 text-blue-700 rounded">
                      Position: <%= question.position %>
                    </span>
                    <span class="px-2 py-1 text-xs font-medium bg-gray-100 text-gray-700 rounded capitalize">
                      <%= question.question_type.humanize %>
                    </span>
                    <% if question.required? %>
                      <span class="px-2 py-1 text-xs font-medium bg-red-100 text-red-700 rounded">
                        Required
                      </span>
                    <% end %>
                  </div>
                  <p class="text-lg font-medium text-gray-900 mb-1"><%= question.question_text %></p>
                  <% if question.placeholder.present? %>
                    <p class="text-sm text-gray-500">Placeholder: <%= question.placeholder %></p>
                  <% end %>
                  <% if question.min_value.present? || question.max_value.present? %>
                    <p class="text-sm text-gray-500">
                      Range: 
                      <%= question.min_value.present? ? question.min_value : "N/A" %> - 
                      <%= question.max_value.present? ? question.max_value : "N/A" %>
                    </p>
                  <% end %>
                  <% if question.allow_other? %>
                    <p class="text-sm text-gray-500">Allows "Other" option</p>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-8 bg-gray-50 rounded-lg border-2 border-dashed border-gray-300 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h3 class="text-sm font-medium text-gray-900 mb-1">No questions yet</h3>
          <p class="text-sm text-gray-500">Add your first question below to get started.</p>
        </div>
      <% end %>
    </div>

    <!-- New Question Form -->
    <div class="bg-white border border-gray-200 rounded-lg p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Add New Question</h2>
      <%= render "form", question: @question, widget: @widget %>
    </div>
  </div>
</div>

