<%= turbo_frame_tag dom_id(@question) do %>
  <div class="bg-white shadow-sm border border-gray-200 rounded-lg p-6 my-4 relative">
    <div class="mb-4 flex items-center justify-between">
      <h3 class="text-lg font-semibold text-gray-900">Edit Question</h3>
      <%= link_to widget_questions_path(@widget), 
          class: "text-gray-500 hover:text-gray-700 font-medium text-sm flex items-center gap-1",
          data: { turbo_frame: dom_id(@question) } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
        Cancel
      <% end %>
    </div>

    <%= render "form", question: @question, widget: @widget %>
  </div>
<% end %>

