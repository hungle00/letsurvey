<div class="flex w-full min-h-screen">
  <%= render "shared/sidebar" %>

  <div class="flex-1 p-8 bg-background">
    <div class="mb-6">
      <div class="flex items-start justify-between">
        <div>
          <p class="text-gray-600 mt-1 font-semibold">
            View and manage your <span class="text-blue-600 font-bold">feedback widget</span>
          </p>
        </div>
        <div class="flex gap-3">
          <%= link_to edit_widget_path(@widget), 
              class: "px-5 py-2.5 border-2 border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 hover:border-gray-400 transition-all duration-300 shadow-sm hover:shadow-md" do %>
            Edit
          <% end %>
          <%= link_to preview_widget_path(@widget.id), 
              target: "_blank",
              class: "px-5 py-2.5 bg-gradient-to-r from-blue-600 to-teal-600 hover:from-blue-700 hover:to-teal-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105" do %>
            Preview
          <% end %>
        </div>
      </div>
    </div>

    <%= render "shared/flash" %>

    <!-- Widget Information Card -->
    <div class="bg-white border border-gray-200 rounded-2xl p-8 mb-6 shadow-lg">
      <div class="flex items-start justify-between mb-6">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-3">
            <h2 class="text-3xl font-bold text-gray-900"><%= @widget.title %></h2>
            <span class="px-4 py-1.5 text-sm font-semibold rounded-full shadow-sm <%= status_badge_class(@widget.status) %>">
              <%= @widget.status.humanize %>
            </span>
          </div>
          <% if @widget.description.present? %>
            <p class="text-gray-600 text-lg"><%= @widget.description %></p>
          <% end %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6 pt-6 border-t border-gray-200">
        <div class="p-4 bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl">
          <p class="text-sm text-blue-600 font-medium mb-1">Status</p>
          <p class="text-xl font-bold text-blue-900"><%= @widget.status.humanize %></p>
        </div>
        <div class="p-4 bg-gradient-to-br from-teal-50 to-teal-100 rounded-xl">
          <p class="text-sm text-teal-600 font-medium mb-1">Responses</p>
          <p class="text-xl font-bold text-teal-900"><%= @widget.responses_count || 0 %></p>
        </div>
        <div class="p-4 bg-gradient-to-br from-emerald-50 to-emerald-100 rounded-xl">
          <p class="text-sm text-emerald-600 font-medium mb-1">Created</p>
          <p class="text-xl font-bold text-emerald-900"><%= @widget.created_at.strftime("%b %d, %Y") %></p>
        </div>
      </div>

      <div class="mt-6 pt-6 border-t border-gray-200">
        <p class="text-sm text-gray-500 mb-2">Form URL</p>
        <% form_url = "#{request.base_url}/forms/#{@widget.slug}" %>
        <div class="flex items-center gap-2" 
          data-controller="clipboard"
          data-clipboard-link-url-value="<%= form_url %>">
          <code class="flex-1 px-3 py-2 bg-gray-50 border border-gray-200 rounded text-sm text-gray-800">
            <%= form_url %>
          </code>
          <button class="px-4 py-2 bg-gradient-to-r from-blue-600 to-teal-600 hover:from-blue-700 hover:to-teal-700 text-white rounded-xl text-sm font-semibold shadow-md hover:shadow-lg transition-all duration-300 transform hover:scale-105" 
            data-action="click->clipboard#copyLink">
            Copy
          </button>
        </div>
      </div>
    </div>

    <!-- Questions Section -->
    <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-6 shadow-lg">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-2xl font-bold text-gray-900">Questions</h3>
        <%= link_to widget_questions_path(@widget), 
            class: "px-5 py-2.5 bg-gradient-to-r from-blue-600 to-teal-600 hover:from-blue-700 hover:to-teal-700 text-white font-semibold rounded-xl shadow-md hover:shadow-lg transition-all duration-300 transform hover:scale-105 text-sm flex items-center gap-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          View Questions
        <% end %>
      </div>

      <div class="space-y-4">
        <% if @widget.questions_count > 0 %>
          <div class="p-4 bg-blue-50 rounded-lg border border-blue-200">
            <p class="text-blue-700 text-center font-medium">
              This widget has <span class="font-bold"><%= @widget.questions_count %></span> <%= "question".pluralize(@widget.questions_count) %>.
            </p>
          </div>
        <% else %>
          <div class="p-4 bg-gray-50 rounded-lg border border-gray-200">
            <p class="text-gray-500 text-center">No questions yet. Add your first question to get started.</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Analytics Section -->
    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-lg">
      <h3 class="text-2xl font-bold text-gray-900 mb-6">Analytics</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="p-5 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105">
          <p class="text-sm text-blue-100 font-medium mb-2">Total Responses</p>
          <p class="text-3xl font-bold text-white"><%= @widget.responses_count || 0 %></p>
        </div>
        <div class="p-5 bg-gradient-to-br from-green-500 to-green-600 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105">
          <p class="text-sm text-green-100 font-medium mb-2">Completion Rate</p>
          <p class="text-3xl font-bold text-white">-</p>
        </div>
        <div class="p-5 bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105">
          <p class="text-sm text-yellow-100 font-medium mb-2">Average Time</p>
          <p class="text-3xl font-bold text-white">-</p>
        </div>
        <div class="p-5 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105">
          <p class="text-sm text-purple-100 font-medium mb-2">Views</p>
          <p class="text-3xl font-bold text-white">0</p>
        </div>
      </div>

      <div class="mt-6 pt-6 border-t border-gray-200 flex justify-end">
        <%= link_to widget_analytics_path(@widget), 
            class: "text-sm text-blue-600 hover:text-blue-700 font-semibold transition-all duration-300 flex items-center gap-2 hover:gap-3 group" do %>
          View Full Analytics
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</div>
