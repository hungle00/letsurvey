<div class="flex w-full min-h-screen">
  <%= render "shared/sidebar" %>

  <div class="flex-1 p-8">
    <div class="mb-6">
      <%= link_to widget_path(@widget), 
          class: "inline-flex items-center text-gray-600 hover:text-gray-900 mb-4" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Widget
      <% end %>

      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Analytics</h1>
          <p class="text-gray-600 mt-1">Performance insights for: <%= @widget.title %></p>
        </div>
      </div>
    </div>

    <!-- Overview Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm text-gray-600 font-medium">Total Responses</p>
          <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= @total_responses %></p>
        <p class="text-xs text-gray-500 mt-1">All time responses</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm text-gray-600 font-medium">Completion Rate</p>
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= @completion_rate %>%</p>
        <p class="text-xs text-gray-500 mt-1">Form completion</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm text-gray-600 font-medium">Average Time</p>
          <svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= @average_time %></p>
        <p class="text-xs text-gray-500 mt-1">To complete survey</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm text-gray-600 font-medium">Total Views</p>
          <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= @total_views %></p>
        <p class="text-xs text-gray-500 mt-1">Form page views</p>
      </div>
    </div>

    <!-- Response Trends Chart -->
    <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Response Trends (Last 7 Days)</h2>
      <div class="h-64 flex items-end justify-between gap-2">
        <% max_count = @response_trends.map { |t| t[:count] }.max || 1 %>
        <% @response_trends.each do |trend| %>
          <div class="flex-1 flex flex-col items-center">
            <div class="w-full bg-blue-100 rounded-t hover:bg-blue-200 transition-colors relative group" 
                 style="height: <%= max_count > 0 ? (trend[:count].to_f / max_count * 100) : 0 %>%">
              <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 hidden group-hover:block bg-gray-800 text-white text-xs px-2 py-1 rounded whitespace-nowrap">
                <%= trend[:count] %> responses
              </div>
            </div>
            <p class="text-xs text-gray-600 mt-2"><%= trend[:date] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Question Statistics -->
    <div class="bg-white border border-gray-200 rounded-lg p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Question Performance</h2>
      
      <% if @questions.any? %>
        <div class="space-y-4">
          <% @question_stats.each do |stat| %>
            <div class="border border-gray-200 rounded-lg p-4">
              <div class="flex items-start justify-between mb-3">
                <div class="flex-1">
                  <p class="font-medium text-gray-900 mb-1"><%= stat[:question].question_text %></p>
                  <div class="flex items-center gap-3">
                    <span class="px-2 py-1 text-xs font-medium bg-gray-100 text-gray-700 rounded capitalize">
                      <%= stat[:question].question_type.humanize %>
                    </span>
                    <% if stat[:question].required? %>
                      <span class="px-2 py-1 text-xs font-medium bg-red-100 text-red-700 rounded">
                        Required
                      </span>
                    <% end %>
                  </div>
                </div>
              </div>
              
              <div class="grid grid-cols-2 gap-4 pt-3 border-t border-gray-100">
                <div>
                  <p class="text-sm text-gray-500 mb-1">Responses</p>
                  <p class="text-lg font-semibold text-gray-900"><%= stat[:response_count] %></p>
                </div>
                <div>
                  <p class="text-sm text-gray-500 mb-1">Completion Rate</p>
                  <p class="text-lg font-semibold text-gray-900"><%= stat[:completion_rate] %>%</p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-8 bg-gray-50 rounded-lg border-2 border-dashed border-gray-300 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h3 class="text-sm font-medium text-gray-900 mb-1">No questions yet</h3>
          <p class="text-sm text-gray-500">Add questions to start tracking analytics.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

