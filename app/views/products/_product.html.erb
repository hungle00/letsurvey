<div class="bg-white shadow-md border border-gray-200 rounded-2xl overflow-hidden hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 group">
  <div class="flex">
    <!-- Image on the left (square) -->
    <div class="flex-shrink-0 w-32 h-32 overflow-hidden rounded-l-2xl">
      <%= image_tag product.image_url.presence || "latte.jpg",
          alt: product.name,
          class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" %>
    </div>

    <!-- Info on the right -->
    <div class="flex-1 p-4 flex flex-col justify-between">
      <div>
        <div class="flex items-start justify-between mb-2">
          <h3 class="text-lg font-bold text-gray-900 line-clamp-2 flex-1 pr-2 group-hover:text-blue-600 transition-colors">
            <%= product.name %>
          </h3>
          <span class="px-3 py-1.5 text-xs font-semibold rounded-full flex-shrink-0 shadow-sm <%= product.active? ? 'bg-gradient-to-r from-green-400 to-green-500 text-white' : product.inactive? ? 'bg-gray-100 text-gray-700' : 'bg-gradient-to-r from-red-400 to-red-500 text-white' %>">
            <%= product.status.humanize %>
          </span>
        </div>

        <% if product.description.present? %>
          <p class="text-sm text-gray-600 mb-3 line-clamp-2">
            <%= product.description %>
          </p>
        <% end %>

        <div class="flex items-center justify-between text-sm mb-3">
          <% if product.category.present? %>
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
              </svg>
              <span class="text-gray-500"><%= product.category %></span>
            </div>
          <% end %>
          <div class="flex items-center px-3 py-1.5 bg-gradient-to-r from-emerald-50 to-teal-50 rounded-lg">
            <svg class="w-4 h-4 mr-1.5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="text-emerald-700 font-bold text-lg">$<%= sprintf("%.2f", product.price) %></span>
          </div>
        </div>
      </div>

      <div class="pt-3 border-t border-gray-100 flex items-center justify-between">
        <span class="text-xs text-gray-500">
          Created: <%= product.created_at.strftime("%b %d, %Y") %>
        </span>
        <div class="flex items-center gap-3">
          <%= link_to "#", 
              class: "px-4 py-1.5 text-blue-600 hover:text-white hover:bg-blue-600 text-sm font-semibold rounded-lg transition-all duration-300" do %>
            Edit
          <% end %>
          <%= link_to "#", 
              method: :delete,
              data: { turbo_confirm: "Are you sure?" },
              class: "px-4 py-1.5 text-red-600 hover:text-white hover:bg-red-600 text-sm font-semibold rounded-lg transition-all duration-300" do %>
            Delete
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

