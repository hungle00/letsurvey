<div class="flex w-full min-h-screen">
  <%= render "shared/sidebar" %>

  <div class="flex-1 p-8">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">Analytics</h1>
      <p class="text-gray-600 mt-1">View analytics for all your widgets</p>
    </div>

    <% if flash[:notice] %>
      <div class="mb-4 p-4 bg-green-50 text-green-700 rounded-lg">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="mb-4 p-4 bg-red-50 text-red-700 rounded-lg">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- Widgets Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% if @widgets.any? %>
        <% @widgets.each do |widget| %>
          <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow">
            <div class="flex items-start justify-between mb-4">
              <h3 class="text-lg font-semibold text-gray-900 line-clamp-2 flex-1"><%= widget.title %></h3>
              <span class="px-2 py-1 text-xs font-medium rounded-full ml-2 <%= status_badge_class(widget.status) %>">
                <%= widget.status.humanize %>
              </span>
            </div>
            
            <% if widget.description.present? %>
              <p class="text-sm text-gray-600 mb-4 line-clamp-2"><%= widget.description %></p>
            <% end %>

            <!-- Stats Preview -->
            <div class="grid grid-cols-2 gap-4 mb-4 pb-4 border-b border-gray-100">
              <div>
                <p class="text-xs text-gray-500 mb-1">Responses</p>
                <p class="text-lg font-semibold text-gray-900"><%= widget.responses_count || 0 %></p>
              </div>
              <div>
                <p class="text-xs text-gray-500 mb-1">Questions</p>
                <p class="text-lg font-semibold text-gray-900"><%= widget.questions.count %></p>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-between">
              <div class="text-xs text-gray-500">
                Created: <%= widget.created_at.strftime("%b %d, %Y") %>
              </div>
              <%= link_to widget_analytics_path(widget), 
                  class: "text-blue-600 hover:text-blue-700 text-sm font-medium flex items-center" do %>
                View Analytics
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <!-- Empty State -->
        <div class="col-span-full">
          <div class="text-center py-12 bg-gray-50 rounded-lg border-2 border-dashed border-gray-300">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">No widgets yet</h3>
            <p class="mt-1 text-sm text-gray-500">Create a widget to start tracking analytics.</p>
            <div class="mt-6">
              <%= link_to new_widget_path, 
                  class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" do %>
                <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                New Widget
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
