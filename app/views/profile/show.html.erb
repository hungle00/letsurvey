<div class="flex w-full min-h-screen">
  <%= render "shared/sidebar" %>

  <div class="flex-1 p-8 bg-blue-50 mx-auto">
    <div class="max-w-4xl mx-auto">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <p class="text-gray-600 font-bold mt-1">Manage your account information</p>
        </div>
        <%= link_to edit_profile_path, 
            class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors flex items-center" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
          Edit Profile
        <% end %>
      </div>

      <%= render "shared/flash" %>

      <!-- Profile Information Card -->
      <div class="bg-white shadow-sm border border-gray-200 rounded-lg p-8">
        <div class="mb-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Account Information</h2>
          <p class="text-gray-600">Your personal profile details</p>
        </div>

        <div class="space-y-6">
          <!-- Email Address (Read-only) -->
          <div class="pb-6 border-b border-gray-200">
            <p class="text-sm text-gray-500 mb-1">Email Address</p>
            <div class="flex items-center">
              <p class="text-lg font-semibold text-gray-900"><%= @user.email_address %></p>
              <span class="ml-3 px-2 py-1 text-xs font-medium text-gray-500 bg-gray-100 rounded">Cannot be changed</span>
            </div>
          </div>

          <!-- Full Name -->
          <div>
            <p class="text-sm text-gray-500 mb-1">Full Name</p>
            <p class="text-lg font-semibold text-gray-900">
              <%= @user.full_name.present? ? @user.full_name : "Not set" %>
            </p>
          </div>

          <!-- Phone Number -->
          <div>
            <p class="text-sm text-gray-500 mb-1">Phone Number</p>
            <p class="text-lg font-semibold text-gray-900">
              <%= @user.phone_number.present? ? @user.phone_number : "Not set" %>
            </p>
          </div>
        </div>

        <!-- Account Metadata -->
        <div class="mt-8 pt-6 border-t border-gray-200">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <p class="text-sm text-gray-500 mb-1">Member Since</p>
              <p class="text-lg font-semibold text-gray-900">
                <%= @user.created_at.strftime("%B %d, %Y") %>
              </p>
            </div>
            <div>
              <p class="text-sm text-gray-500 mb-1">Last Updated</p>
              <p class="text-lg font-semibold text-gray-900">
                <%= @user.updated_at.strftime("%B %d, %Y") %>
              </p>
            </div>
          </div>
        </div>

        <!-- Subscription Link --> 
        <div class="mt-8 pt-6 border-t border-gray-200">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-gray-500 mb-1">Subscription</p>
              <p class="text-lg font-semibold text-gray-900">
                <%= Current.user.has_active_subscription? ? "Active" : "No active subscription" %>
              </p>
            </div>
            <%= link_to subscription_path, 
                class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors flex items-center" do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
              </svg>
              <%= Current.user.has_active_subscription? ? "Manage Subscription" : "Subscribe Now" %>
            <% end %>
          </div>
      </div>
    </div>
  </div>
</div>
